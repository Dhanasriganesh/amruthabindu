# Amrutha Bindu — environment variables

# Firebase (client — Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server API routes — Ecwid sync, tracking)
# Option A: full service account JSON (one line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B: separate fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Site branding
VITE_SITE_URL=https://amruthabindu.in
VITE_CONTACT_EMAIL=contact@amruthabindu.in
VITE_SUPPORT_EMAIL=support@amruthabindu.in

# Razorpay
VITE_RZP_KEY_ID=
VITE_RZP_SECRET_KEY=
VITE_RZP_PAYMENT_PAGE_URL=

# Admin panel — comma-separated Firebase Auth emails allowed to access /admin
VITE_ADMIN_EMAILS=admin@amruthabindu.in

# Email (SMTP)
SMTP_USER=
SMTP_PASS=
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=contact@amruthabindu.in

# WhatsApp
VITE_WHATSAPP_PHONE=

# Ecwid
VITE_ECWID_STORE_ID=
VITE_ECWID_SECRET_TOKEN=

PORT=3001

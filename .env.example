# Amrutha Bindu — environment variables

# Firebase (client — Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server API routes — Shiprocket sync, tracking)
# Option A: full service account JSON (one line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B: separate fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Site branding
VITE_SITE_URL=https://amruthabindu.in
VITE_CONTACT_EMAIL=amruthabindutnd@gmail.com
VITE_SUPPORT_EMAIL=amruthabindutnd@gmail.com

# Razorpay (server — never expose KEY_SECRET to the client)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay (client — key ID only)
VITE_RAZORPAY_KEY_ID=
# Legacy alias (optional)
# VITE_RZP_KEY_ID=
# VITE_RZP_PAYMENT_PAGE_URL=

# Admin panel — comma-separated Firebase Auth emails allowed to access /admin
VITE_ADMIN_EMAILS=admin@amruthabindu.in

# Email (SMTP)
SMTP_USER=
SMTP_PASS=
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_EMAIL=amruthabindutnd@gmail.com

# WhatsApp
VITE_WHATSAPP_PHONE=918142554488

# Shiprocket (delivery & tracking)
# Set SHIPROCKET_ENABLED=false to skip shipping API calls (e.g. while testing payments)
SHIPROCKET_ENABLED=true
# Create API user: Shiprocket Panel → Settings → API → Configure → Create API User
SHIPROCKET_API_EMAIL=
SHIPROCKET_API_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Shop
SHIPROCKET_DEFAULT_WEIGHT=0.5
SHIPROCKET_DEFAULT_LENGTH=10
SHIPROCKET_DEFAULT_BREADTH=10
SHIPROCKET_DEFAULT_HEIGHT=10

# Optional: free delivery above this order value (₹). Leave empty or 0 to always charge Shiprocket rate.
# FREE_SHIPPING_MIN_ORDER=999
# How to pick the checkout delivery fee: recommended (matches Shiprocket default) or cheapest
SHIPPING_RATE_MODE=recommended
# Minimum billable package weight in kg (Shiprocket uses 0.5 kg slabs)
SHIPROCKET_MIN_WEIGHT=0.5
# Optional: add flat ₹ markup on top of the selected courier rate
# SHIPPING_MARKUP=0

PORT=3001
